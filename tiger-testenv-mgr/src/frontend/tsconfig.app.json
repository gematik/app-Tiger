{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "target": "ES2022",
    "lib": [
      "DOM.Iterable",
      "DOM",
      "ES2023"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "tiger-topology-visualizer": [
        "../../../tiger-topology-visualizer/src/frontend/tiger-topology-visualizer/src/index.ts"
      ],
      "tiger-topology-visualizer/*": [
        "../../../tiger-topology-visualizer/src/frontend/tiger-topology-visualizer/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*.ts"
  ]
}
